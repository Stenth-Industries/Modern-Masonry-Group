generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Example {
  id        Int      @id @default(autoincrement())
  message   String
  createdAt DateTime @default(now())
}

model User {
    id        Int      @id @default(autoincrement())
    name      String
    email     String   @unique
    password  String
    createdAt DateTime @default(now())
}